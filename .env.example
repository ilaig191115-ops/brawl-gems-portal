# Brawl Stars official API token (from https://developer.brawlstars.com).
#
# IMPORTANT: the token is IP-locked. This app routes through the RoyaleAPI
# proxy, so on your token you must whitelist the proxy IP:  45.79.218.79
# (The same token then works both locally and on Vercel.)
#
# Local dev: copy this file to `.env.local` and paste your token below.
# Production: add BRAWL_STARS_API_TOKEN in Vercel → Settings → Environment Variables.
BRAWL_STARS_API_TOKEN=
